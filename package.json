{
  "name": "engraving-processor-pro",
  "version": "1.0.0",
  "description": "Application for processing historical engravings and document scans",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && npm run lint && vite build",
    "build:fast": "vite build",
    "start": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist node_modules/.vite",
    "stats": "npm run build && du -sh dist && find dist -type f | wc -l"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "pinia": "^3.0.0",
    "wasm-vips": "^0.0.13"
  },
  "devDependencies": {
    "vite": "^6.3.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "vue-tsc": "^2.1.6",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "vite-plugin-wasm": "^3.4.0",
    "vite-plugin-top-level-await": "^1.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.0",
    "@types/node": "^22.0.0",
    "@eslint/js": "^9.28.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.28.0",
    "eslint-plugin-vue": "^9.30.0",
    "vue-eslint-parser": "^9.4.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [
    "image-processing",
    "engraving",
    "document-scanning",
    "wasm",
    "vue",
    "typescript"
  ],
  "author": "Ervins Strauhmanis",
  "license": "MIT"
}