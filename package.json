{
  "name": "engraving-processor-pro",
  "version": "1.0.0",
  "description": "Application for processing historical engravings and document scans",
  "type": "module",
  "scripts": {
    "build": "echo '🔧 Building Engraving Processor Pro...' && rm -rf dist .vite && vue-tsc --noEmit --skipLibCheck && eslint . --quiet --max-warnings 0 && vite build && echo '✅ Build complete'",
    "start": "echo '🚀 Starting Engraving Processor Pro...' && vite preview --host --port 4173",
    "dev": "echo '🛠️ Starting development server...' && vite --host",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "pinia": "^3.0.0",
    "wasm-vips": "^0.0.13"
  },
  "devDependencies": {
    "vite": "^6.3.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "vue-tsc": "^2.1.6",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "vite-plugin-wasm": "^3.4.0",
    "vite-plugin-top-level-await": "^1.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "@types/jsdom": "^21.1.7",
    "@vitest/coverage-v8": "^3.2.0",
    "@vitest/ui": "^3.2.0",
    "@types/node": "^22.0.0",
    "@eslint/js": "^9.28.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.28.0",
    "eslint-plugin-vue": "^9.30.0",
    "vue-eslint-parser": "^9.4.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [
    "image-processing",
    "engraving",
    "document-scanning",
    "wasm",
    "vue",
    "typescript",
    "webworker",
    "computer-vision"
  ],
  "author": "Ervins Strauhmanis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/engraving-processor-pro.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/engraving-processor-pro/issues"
  },
  "homepage": "https://github.com/your-username/engraving-processor-pro#readme"
}