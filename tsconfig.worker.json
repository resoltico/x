{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020", "WebWorker"],
    "types": ["vite/client"],
    "noEmit": true,
    "strictNullChecks": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "include": [
    "src/workers/**/*.ts",
    "src/types/worker*.d.ts",
    "src/types/index.ts",
    "src/types/browser.d.ts",
    "src/modules/processing/**/*.ts"
  ],
  "exclude": [
    "src/**/*.vue",
    "src/components/**/*",
    "src/stores/**/*",
    "node_modules"
  ]
}